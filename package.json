{
  "name": "mcp-hello-typescript-server",
  "version": "0.1.0",
  "description": "A minimal MCP server in TypeScript: a server_info health check and a multilingual greeting tool",
  "license": "MIT",
  "author": "Mitch Allen <npm@mitchallen.com>",
  "homepage": "https://github.com/mitchallen/mcp-hello-typescript-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchallen/mcp-hello-typescript-server"
  },
  "keywords": [
    "mcp",
    "hello",
    "greeting",
    "starter"
  ],
  "type": "module",
  "bin": {
    "mcp-hello-typescript-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
